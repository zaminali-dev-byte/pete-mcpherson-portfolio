---
interface Props {
  title: string;
  description: string;
  href?: string;
}

const { title, description, href = '#' } = Astro.props;
---

<article
  class="group border border-black/15 bg-white p-6 transition-colors hover:border-black sm:p-8"
>
  <h3 class="font-heading text-2xl leading-none text-black sm:text-3xl">
    <a
      href={href}
      class="transition-opacity group-hover:underline focus:outline-none"
    >
      {title}
    </a>
  </h3>
  <p class="mt-4 font-body text-base leading-relaxed text-black/75">
    {description}
  </p>
</article>
