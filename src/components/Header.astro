---
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHome = pathname === '/';

const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(`${href}/`);
}
---

<header
  class:list={[
    isHome ? 'border-b border-white/15 bg-black' : 'border-b border-black/10 bg-white',
  ]}
>
  <div
    class="mx-auto flex max-w-content items-center justify-between gap-6 px-6 py-5 sm:px-8"
  >
    <a
      href="/"
      class:list={[
        'font-heading text-xl tracking-wide sm:text-2xl',
        isHome ? 'text-white' : 'text-black',
      ]}
      aria-label="Pete McPherson — Home"
    >
      Pete McPherson
    </a>
    <nav aria-label="Primary">
      <ul class="flex items-center gap-5 sm:gap-8">
        {
          links.map(({ href, label }) => {
            const active = isActive(href);
            return (
              <li>
                <a
                  href={href}
                  class:list={[
                    'nav-link font-body relative text-sm tracking-wide uppercase sm:text-base',
                    isHome ? 'text-white' : 'text-black',
                    active && 'font-semibold',
                  ]}
                  aria-current={active ? 'page' : undefined}
                >
                  {label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -0.2em;
    width: 100%;
    height: 2px;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .nav-link:hover::after,
  .nav-link[aria-current='page']::after {
    transform: scaleX(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-link::after {
      transition: none;
    }
  }
</style>
